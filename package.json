{
  "name": "wedbav",
  "version": "0.2.1",
  "type": "module",
  "main": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "files": [
    "lib"
  ],
  "scripts": {
    "dev": "node --env-file=.env --watch main-dev.ts",
    "dev:deno": "deno serve -A --watch --env-file=.env main-dev.ts",
    "dev:bun": "bun --watch main-dev.ts",
    "build": "tsdown",
    "start": "node main.ts",
    "type-check": "tsc --noEmit",
    "check": "biome check --unsafe",
    "format": "biome format",
    "lint": "biome lint",
    "test": "node --test src/*.test.ts",
    "coverage": "node --experimental-test-coverage --test src/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/standard-validator": "^0.2.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "@ricsam/linkfs": "^2.0.8",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "kysely": "^0.29.4",
    "kysely-postgres-js": "^3.0.0",
    "memfs": "^4.64.0",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/bun": "^1.3.14",
    "@types/deno": "^2.7.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsdown": "^0.22.13",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YieldRay/wedbav.git"
  },
  "bugs": {
    "url": "https://github.com/YieldRay/wedbav/issues"
  },
  "homepage": "https://github.com/YieldRay/wedbav#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
