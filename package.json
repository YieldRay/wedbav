{
  "name": "wedbav",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --env-file=.env --watch main.ts",
    "dev:deno": "deno serve -A --watch --env-file=.env index.ts",
    "dev:bun": "bun --watch main.ts",
    "build": "bun build.ts",
    "build:lib": "tsdown",
    "start": "node main.ts",
    "type-check": "tsc --noEmit",
    "check": "biome check --unsafe",
    "format": "biome format",
    "lint": "biome lint",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/standard-validator": "^0.1.5",
    "@libsql/kysely-libsql": "^0.4.1",
    "@ricsam/linkfs": "^2.0.8",
    "@types/pg": "^8.20.0",
    "@vercel/functions": "^3.4.3",
    "hono": "^4.12.10",
    "hono-openapi": "^1.3.0",
    "kysely": "^0.28.15",
    "kysely-postgres-js": "^3.0.0",
    "memfs": "^4.57.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@types/bun": "^1.3.11",
    "@types/deno": "^2.5.0",
    "@types/node": "^24.12.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YieldRay/wedbav.git"
  },
  "bugs": {
    "url": "https://github.com/YieldRay/wedbav/issues"
  },
  "homepage": "https://github.com/YieldRay/wedbav#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
