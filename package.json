{
  "name": "wedbav",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --env-file=.env --watch main.ts",
    "dev:deno": "deno serve -A --watch --env-file=.env main.ts",
    "dev:bun": "bun --watch main.ts",
    "build:app": "bun build.ts",
    "build:lib": "tsdown",
    "start": "node main.ts",
    "type-check": "tsc --noEmit",
    "check": "biome check --unsafe",
    "format": "biome format",
    "lint": "biome lint",
    "test": "node --test src/*.test.ts",
    "coverage": "node --experimental-test-coverage --test src/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/standard-validator": "^0.2.2",
    "@libsql/kysely-libsql": "^0.4.1",
    "@ricsam/linkfs": "^2.0.8",
    "@vercel/functions": "^3.5.0",
    "hono": "^4.12.16",
    "hono-openapi": "^1.3.0",
    "kysely": "^0.28.17",
    "kysely-postgres-js": "^3.0.0",
    "memfs": "^4.57.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.3.13",
    "@types/deno": "^2.5.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YieldRay/wedbav.git"
  },
  "bugs": {
    "url": "https://github.com/YieldRay/wedbav/issues"
  },
  "homepage": "https://github.com/YieldRay/wedbav#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
